# ──────────────────────────────────────────────────────────────
# LLM 分析配置
# ──────────────────────────────────────────────────────────────

# LLM Provider: claude | openai | gemini | mock
LLM_PROVIDER=mock

# 是否在转写后自动启用 LLM 分析
USE_LLM_ANALYSIS=false

# LLM 失败时是否回退到关键词分析（默认 true）
LLM_FALLBACK_TO_RULES=true

# ──────────────────────────────────────────────────────────────
# Claude (Anthropic)
# ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# 可选：覆盖默认模型（默认 claude-sonnet-4-20250514）
# CLAUDE_MODEL=claude-sonnet-4-20250514

# ──────────────────────────────────────────────────────────────
# OpenAI
# ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# 可选：覆盖默认模型（默认 gpt-4o-mini）
# OPENAI_MODEL=gpt-4o-mini

# ──────────────────────────────────────────────────────────────
# Google Gemini
# ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=...

# 可选：覆盖默认模型（默认 gemini-2.0-flash）
# GEMINI_MODEL=gemini-2.0-flash
